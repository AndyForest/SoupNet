# Root env vars shared across services.
# Copy to .env and fill in values. Never commit .env files.

# ── Postgres ────────────────────────────────────────────────────────────────
# Individual PG* vars — matches what ECS uses in production (PGPASSWORD comes
# from the auto-rotating RDS master user secret). Locally all vars are in .env.
# SoupNet's local stack uses port 5633 so it can coexist with claimNet on 5533.
PGHOST=localhost
PGPORT=5633
PGUSER=claimnet
PGPASSWORD=claimnet
PGDATABASE=claimnet

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Use: openssl rand -hex 32 to generate:
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Dev auto-setup ───────────────────────────────────────────────────────────
# If set and no users exist, a system user is auto-created on startup.
DEV_USERNAME=admin@soup.net
DEV_PASSWORD=changeme123

# ── Test auto-setup ──────────────────────────────────────────────────────────
# If set, integration tests use this account instead of creating throwaway users.
# Also auto-created on startup alongside the dev user (dev environment only).
TEST_USERNAME=test@test.local
TEST_PASSWORD=test-password-123

# ── Email ────────────────────────────────────────────────────────────────────
# Local dev: Mailpit (docker-compose sets these automatically)
# Production: AWS SES (SMTP endpoint from SES console)
SMTP_HOST=localhost
SMTP_PORT=1125
EMAIL_FROM=noreply@soup.net

# SES bounce/complaint pipeline: name of the SES configuration set to stamp on
# outgoing mail (X-SES-CONFIGURATION-SET header). Production-only; leave unset
# locally — Mailpit and non-SES SMTP servers ignore the header.
# SES_CONFIGURATION_SET=

# ── Embedding ─────────────────────────────────────────────────────────────────
# Required for vector search. Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Embedding provider for the worker pipeline:
#   gemini             — real Gemini API (default; required in production)
#   stub               — deterministic fake 3072-dim vectors. No API calls, no
#                        quota. Recommended for local dev so integration tests
#                        don't burn quota. The cache code path is still fully
#                        exercised — only the leaf API call is replaced. One
#                        opt-in test (gemini-embeddings.test.ts) always uses real
#                        Gemini when GEMINI_API_KEY is set.
#   local              — in-process CPU model via @huggingface/transformers
#                        (ONNX). No external service, no API key. Vectors are
#                        zero-padded into the existing halfvec(3072) column
#                        (lossless for cosine). Great for tire-kickers, CI smoke
#                        tests, and no-external-API self-hosters.
#   openai-compatible  — any OpenAI-style /v1/embeddings endpoint (llama.cpp,
#                        LM Studio, Ollama, TEI, vLLM). Set EMBEDDINGS_BASE_URL +
#                        EMBEDDINGS_MODEL below.
# One embedding model per deployment — vectors from different models occupy
# different semantic spaces and are never mixed. Switching provider/model on a
# populated corpus requires re-embedding (search fails safe / returns nothing
# until then).
EMBEDDINGS_PROVIDER=stub

# Model id. Meaning depends on the provider:
#   local              — the FULL Hugging Face repo id transformers.js loads (org
#                        included), NOT a bare name. Default (when empty):
#                        Xenova/bge-small-en-v1.5 (384-dim, ~23 MB, no
#                        query/passage prefix needed). Xenova/all-MiniLM-L6-v2 is
#                        the most-proven fallback (also 384-dim). The Docker image
#                        bakes the default model for offline use; to run a
#                        different model either rebuild with
#                        --build-arg HF_MODEL=<repo id> or mount an HF_HOME volume
#                        and unset HF_HUB_OFFLINE/TRANSFORMERS_OFFLINE.
#   openai-compatible  — the model id the endpoint reports/serves.
# Leave empty to use the provider default. Ignored by gemini/stub.
EMBEDDINGS_MODEL=

# openai-compatible only: base URL of the /v1/embeddings endpoint, and an
# optional bearer key (leave empty when the harness needs no auth). The model's
# native dimension must be <= 3072 (or MRL-capable) so it fits the halfvec(3072)
# column. Example base URLs:
#   llama.cpp (llama-server --embedding --pooling mean --port 8080)  http://localhost:8080/v1
#   LM Studio (Developer -> Start Server)                            http://localhost:1234/v1
#   Ollama    (ollama pull nomic-embed-text) — alternative           http://localhost:11434/v1
# When Soup.net runs in its own container, localhost above means the container —
# use host.docker.internal (Docker Desktop) or the host IP for a harness on the host.
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=

# ── Synthesis ─────────────────────────────────────────────────────────────────
# The premium `synthesize` feature (retrieval synthesis) makes one server-side
# LLM call to distil a check's exemplars into a "current preference profile".
# Reuses the same GEMINI_API_KEY as embeddings above.
#
# Provider:
#   gemini  — real Gemini generateContent (default; required for real synthesis)
#   stub    — deterministic profile, no LLM call. Recommended for local dev/tests
#             so the path is exercised without burning quota (mirrors EMBEDDINGS).
SYNTHESIS_PROVIDER=stub
# Model used when SYNTHESIS_PROVIDER=gemini. Swap the model by changing this env.
SYNTHESIS_MODEL=gemini-3.5-flash

# ── App URLs ─────────────────────────────────────────────────────────────────
# Backend listening port for non-docker dev (`npm run dev:backend`).
# Docker overrides this to 3001 internally and maps host:3101 → container:3001.
PORT=3101
BACKEND_URL=http://localhost:3101

# Frontend dev server port (Vite reads FRONTEND_PORT from this file via vite.config.ts).
FRONTEND_PORT=5273
FRONTEND_URL=http://localhost:5273

# Frontend's URL for the backend, exposed to client code via import.meta.env.VITE_API_BASE.
# Vite picks up VITE_*-prefixed vars from this file at dev-server start (envDir = repo root).
# CI overrides at production build time (e.g., https://mcp.soup.net).
VITE_API_BASE=http://localhost:3101

MCP_PORT=3102

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

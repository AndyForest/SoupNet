# Root env vars shared across services.
# Copy to .env and fill in values. Never commit .env files.

# ── Postgres ────────────────────────────────────────────────────────────────
# Individual PG* vars — matches what ECS uses in production (PGPASSWORD comes
# from the auto-rotating RDS master user secret). Locally all vars are in .env.
# SoupNet's local stack uses port 5633 so it can coexist with claimNet on 5533.
PGHOST=localhost
PGPORT=5633
PGUSER=claimnet
PGPASSWORD=claimnet
PGDATABASE=claimnet

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Use: openssl rand -hex 32 to generate:
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Dev auto-setup ───────────────────────────────────────────────────────────
# If set and no users exist, a system user is auto-created on startup.
DEV_USERNAME=admin@soup.net
DEV_PASSWORD=changeme123

# ── Test auto-setup ──────────────────────────────────────────────────────────
# If set, integration tests use this account instead of creating throwaway users.
# Also auto-created on startup alongside the dev user (dev environment only).
TEST_USERNAME=test@test.local
TEST_PASSWORD=test-password-123

# ── Email ────────────────────────────────────────────────────────────────────
# Local dev: Mailpit (docker-compose sets these automatically)
# Production: AWS SES (SMTP endpoint from SES console)
SMTP_HOST=localhost
SMTP_PORT=1125
SMTP_FROM=noreply@soup.net

# ── Embedding ─────────────────────────────────────────────────────────────────
# Required for vector search. Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Embedding provider for the worker pipeline:
#   gemini  — real Gemini API (default; required in production)
#   stub    — deterministic fake 3072-dim vectors. No API calls, no quota.
#             Recommended for local dev so integration tests don't burn quota.
#             The cache code path is still fully exercised — only the leaf API
#             call is replaced. One opt-in test (gemini-embeddings.test.ts)
#             always uses real Gemini when GEMINI_API_KEY is set.
EMBEDDINGS_PROVIDER=stub

# ── App URLs ─────────────────────────────────────────────────────────────────
# Backend listening port for non-docker dev (`npm run dev:backend`).
# Docker overrides this to 3001 internally and maps host:3101 → container:3001.
PORT=3101
BACKEND_URL=http://localhost:3101

# Frontend dev server port (Vite reads FRONTEND_PORT from this file via vite.config.ts).
FRONTEND_PORT=5273
FRONTEND_URL=http://localhost:5273

# Frontend's URL for the backend, exposed to client code via import.meta.env.VITE_API_BASE.
# Vite picks up VITE_*-prefixed vars from this file at dev-server start (envDir = repo root).
# CI overrides at production build time (e.g., https://mcp.soup.net).
VITE_API_BASE=http://localhost:3101

MCP_PORT=3102

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

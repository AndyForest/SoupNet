# Backend URL — used for MCP setup configs and external links shown to users/agents.
# In dev: http://localhost:3001 (default). In prod: https://mcp.soup.net
VITE_BACKEND_URL=http://localhost:3001

# API base for SPA fetch calls. Full URL to the backend. Defaults to
# http://localhost:3001 in dev, must be set at build time in prod.
# VITE_API_BASE=https://mcp.soup.net

# Supply-chain hardening (added 2026-05-12 in response to the Mini Shai-Hulud
# TanStack and Axios npm worm incidents — see docs/security/security-audit-*).

# Block packages newer than 7 days. The dominant npm worm pattern is a
# short-lived malicious publish that gets pulled within hours once detected.
# A 7-day quarantine blocks installs in the cache-poisoning window without
# materially slowing legitimate updates.
#
# Requires npm >= 11.10.0 (added 2026-02-11). Pair with `engines.npm` in
# the root package.json so `npm install` surfaces the version mismatch.
#
# Emergency override (use only after manual review of a specific patch):
#   npm install <pkg> --min-release-age=0
min-release-age=7

# New installs land as pinned versions in package.json (no `^` caret).
# Combined with the committed package-lock.json and CI's `npm ci`, every
# version change is a deliberate decision in a reviewable diff.
save-exact=true

# Refuse to install when the local Node/npm don't match the engines field
# in the root package.json. **Load-bearing for min-release-age above**:
# the directive is only enforced by npm >= 11.10, so without engine-strict
# a dev on an older npm would silently get no cooldown protection on
# `npm install`. engine-strict forces them to upgrade first.
#
# If you hit EBADENGINE locally:
#   - Bump Node to 24 LTS (nvm install 24 / nvm use 24)
#   - npm install -g npm@11.10.0   (or whatever the engines field requires)
engine-strict=true

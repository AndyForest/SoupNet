# Backend environment variables
# Copy to .env and fill in values. Never commit .env.

DATABASE_URL=postgresql://claimnet:claimnet@localhost:5432/claimnet
PAYLOAD_SECRET=change-me-to-a-random-64-char-string

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_ARTIFACT_CACHE=claimnet-artifact-cache
S3_BUCKET_ARTIFACT_PERMANENT=claimnet-artifact-permanent

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@claimnet.local

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

{
  "name": "@soupnet/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --no-splitting --out-dir dist --external @huggingface/transformers --external onnxruntime-node",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint -c ../../eslint.config.js src/"
  },
  "dependencies": {
    "@soupnet/contracts": "*",
    "@soupnet/db": "*",
    "@soupnet/domain": "*",
    "@hono/node-server": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^9.0.1",
    "pg-boss": "^10.0.0",
    "postgres": "^3.4.0",
    "sharp": "^0.35.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@soupnet/config": "*",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/nodemailer": "^7.0.11",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  }
}

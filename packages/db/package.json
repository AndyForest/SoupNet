{
  "name": "@soupnet/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.json && tsup src/index.ts src/schema/index.ts --format esm --no-splitting",
    "typecheck": "tsc --noEmit",
    "lint": "eslint -c ../../eslint.config.js src/",
    "db:generate": "drizzle-kit generate && npm run generate:data-model --prefix ../..",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@soupnet/contracts": "*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@soupnet/config": "*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  }
}
